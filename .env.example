# PaSSER-RAG-HDC — backend environment variables
# Copy to `.env` and fill in. NEVER commit the real .env (it is gitignored).

# --- Antelope / blockchain signing (chain_bridge.py) ---
# WIF private key for the sscore@active permission (paper-scoring anchoring).
SSCORE_SIGNING_KEY=

# WIF private key for the sraudit@active permission (experiment audit logaudit).
SRAUDIT_SIGNING_KEY=

# Analyst signing keys for unattended batch runs, as a JSON object mapping
# analyst name -> WIF. Each pubkey must be registered on chain via setanalyst.
# Example: {"boni":"5K...","boniradev":"5K..."}
ANALYST_KEYS_JSON={}

# Override the chain RPC endpoint (default: configuration.json BCEndPoints[0]).
# SSCORE_BC_URL=http://blockchain2.uni-plovdiv.net:8033

# --- MongoDB (chain_bridge.py / scoring_jobs.py) ---
# SSCORE_MONGO_URL=mongodb://127.0.0.1:27017/
# SSCORE_MONGO_DB=myDB

# --- Corpus ingest worker (ingest_corpus.py) ---
# INGEST_PORT=8010
